# Copy to .local/oneclick.env and fill real values.
# This file contains no real secrets.

# Required: LLM key injected into freewill/aibot-llm-secret
OPENAI_API_KEY=

# Required: internal token for /v1/bots/upgrade auth
UPGRADE_INTERNAL_TOKEN=

# Optional: upgrade repo credentials for HTTP clone
UPGRADE_REPO_USER=
UPGRADE_REPO_TOKEN=

# Optional: override upgrade repo URL used by clawcolony deployment
UPGRADE_REPO_URL=git@github.com:clawcolony/clawcolony.git

# Optional: OpenClaw runtime defaults
BOT_DEFAULT_IMAGE=openclaw:onepod-dev
BOT_OPENCLAW_MODEL=openai/gpt-5.1-codex
BOT_ENV_SECRET_NAME=aibot-llm-secret
CLAWCOLONY_DEPLOYER_API_BASE_URL=http://clawcolony-deployer.clawcolony.svc.cluster.local:8080
# Keep empty for per-user git secret mode (recommended)
BOT_GIT_SSH_SECRET_NAME=
BOT_GIT_SSH_HOST=github.com

# GitHub provisioning mode:
# false -> real GitHub API (requires GITHUB_* below)
# true  -> mock mode (no real repo/deploy-key creation)
GITHUB_API_MOCK_ENABLED=false

# Required when GITHUB_API_MOCK_ENABLED=false
GITHUB_TOKEN=
GITHUB_OWNER=clawcolony
GITHUB_MACHINE_USER=claw-archivist

# Optional when mock enabled
GITHUB_API_MOCK_OWNER=clawcolony
GITHUB_API_MOCK_MACHINE_USER=claw-archivist
GITHUB_API_MOCK_RELEASE_TAG=v2026.3.1

# Optional bootstrap defaults
AGENTS=3
IMAGE=clawcolony:dev
WAIT_TIMEOUT=300s
API_PORT=18080
DEPLOYER_API_PORT=18081
SPLIT_SERVICES=false
REGISTER_TIMEOUT_SECONDS=2400
REGISTER_POLL_SECONDS=5
REGISTER_FAIL_FAST=true
